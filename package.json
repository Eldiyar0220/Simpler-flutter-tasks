            "Flavor Build icon -> show",
            "Flavor Build icon -> hide"
          ],
          "description": "Complete String with hide or show Icon"
        },
        "SimplerFlutterTasks.easyLocalizationsIcon": {
          "type": "string",
          "default": "hide",
          "enum": [
            "show",
            "hide"
          ],
          "enumDescriptions": [
            "Easy Localizations icon -> show",
            "Easy Localizations icon -> hide"
          ],
          "description": "Complete String with hide or show Icon"
        },
        "SimplerFlutterTasks.easyLocalizationFirst": {
          "type": "string",
          "default": "dart run easy_localization:generate -S assets/langs -O lib/langs",
          "description": "Easy Localizations < codegen_loader.g.dart > if u change the command reload Vs Code"
        },
        "SimplerFlutterTasks.easyLocalizationSecond": {
          "type": "string",
          "default": "dart run easy_localization:generate -S assets/langs -f keys -o locale_keys.g.dart",
          "description": "Easy Localizations < locale_keys.g.dart > if u change the command reload Vs Code"
        },
        "SimplerFlutterTasks.customCommandsList": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "description": "Label for the Custom Command"
              },
              "enabled": {
                "type": "boolean",
                "default": true,
                "description": "Label for the Custom Command"
              },
              "color": {
                "type": "string",
                "default": "white",
                "format": "color",
                "description": "Label for the Custom Command"
              },
              "command": {
                "type": "string",
                "default": "flutter build apk",
                "description": "Initial state of the Custom Command"
              },
              "warningDialog": {
                "type": "boolean",
                "default": false,
                "description": "Protection Against Accidental Clicks"
              },
              "askerForCommand": {
                "type": "boolean",
                "default": false,
                "description": "Ask from user"
              },
              "startAfter": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "List of labels of other commands that must complete before this command can run"
              },
              "position": {
                "type": "string",
                "default": "left",
                "enum": [
                  "left",
                  "right"
                ],
                "description": "The alignment of the status bar item (left or right)."
              }
            }
          },
          "description": "List of Custom Commands"
        },
        "SimplerFlutterTasks.createNewTerminal": {
          "type": "boolean",
          "default": false,
          "enum": [
            false,
            true
          ],
          "enumDescriptions": [
            "The Command -> start on opened Terminal",
            "The Command -> create new Terminal"
          ],
          "description": "Complete String with hide or show Icon"
        },
        "SimplerFlutterTasks.colorized": {
          "type": "boolean",
          "default": false,
          "enum": [
            false,
            true
          ],
          "enumDescriptions": [
            "Colorized -> true",
            "Colorized -> false"
          ],
          "description": "Complete String with hide or show Icon"
        },
        "SimplerFlutterTasks.treeViewCopyText": {
          "type": "boolean",
          "default": false,
          "enum": [
            false,
            true
          ],
          "enumDescriptions": [
            "Copy Text -> true",
            "Copy Text -> false"
          ],
          "description": "Complete String with hide or show Icon"
        },
        "SimplerFlutterTasks.Flavors": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Path to the main file (e.g., lib/main) -- lib/main_prod, lib/main_dev, lib/main_stagging ",
              "default": "lib/main"
            },
            "flavors": {
              "type": "array",
              "items": {
                "type": "object",
                "default": [
                  {
                    "title": "prod",
                    "package": "com.kp.megapay.kg"
                  },
                  {
                    "title": "staging",
                    "package": "com.kp.megapay.stagging"
                  },
                  {
                    "title": "dev",
                    "package": "com.kp.megapay.dev"
                  }
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "Flavor title (e.g., prod)"
                  },
                  "package": {
                    "type": "string",
                    "description": "Package name (e.g., com.mega.kg)"
                  }
                },
                "required": [
                  "title",
                  "package"
                ]
              }
            }
          },
          "required": [
            "path",
            "flavors"
          ],
          "description": "Configuration for Flutter flavors"
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.80.0",
    "@vscode/test-electron": "^2.3.4",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.47.0",
    "glob": "^10.3.3",
    "mocha": "^10.2.0",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "axios": "^1.5.1",
    "fast-xml-parser": "^4.3.1",
    "vsce": "^1.97.0"
  }
}
{
  "name": "simpler-flutter-tasks",
  "displayName": "Simpler Flutter Tasks",
  "repository": {
    "type": "git",
    "url": "https://github.com/Eldiyar0220/simpler-flutter-tasks"
  },
  "description": "Flutter quick commands",
  "publisher": "Eldiyar-Dev",
  "version": "3.2.0",
  "icon": "images/eldiyar_profile_icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Snippets",
    "Linters",
    "Formatters",
    "Debuggers",
    "Testing"
  ],
  "keywords": [
    "Flutter",
    "Dart",
    "Snippets",
    "commands",
    "fast commands"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:flutter-tasks.activateFlavor"
  ],
  "main": "./extension.js",
  "enabledApiProposals": [],
  "contributes": {
    "commands": [
      {
        "command": "flutter-tasks.openbundleFolder",
        "title": "Edit",
        "icon": {
          "light": "flutter_helpers/explorer/assets/open_ios_ipa_folders.gif",
          "dark": "flutter_helpers/explorer/assets/open_ios_ipa_folders.gif"
        }
      },
      {
        "command": "flutter-tasks.openApkFolder",
        "title": "Edit",
        "icon": {
          "light": "flutter_helpers/explorer/assets/open_ios_ipa_folders.gif",
          "dark": "flutter_helpers/explorer/assets/open_ios_ipa_folders.gif"
        }
      },
      {
        "command": "flutter-tasks.openIos",
        "title": "Edit",
        "icon": {
          "light": "flutter_helpers/explorer/assets/open_ios_ipa_folders.gif",
          "dark": "flutter_helpers/explorer/assets/open_ios_ipa_folders.gif"
        }
      },
      {
        "command": "flutter-tasks.editLocale",
        "title": "Edit",
        "icon": {
          "light": "flutter_helpers/explorer/assets/edit_locale.gif",
          "dark": "flutter_helpers/explorer/assets/edit_locale.gif"
        }
      },
      {
        "command": "flutter-tasks.refreshEntry",
        "title": "Refresh",
        "icon": {
          "light": "flutter_helpers/explorer/assets/refresh.svg",
          "dark": "flutter_helpers/explorer/assets/refresh.svg"
        }
      },
      {
        "command": "flutter-tasks.runTheCommand",
        "title": "Run The Command",
        "icon": {
          "light": "flutter_helpers/explorer/assets/start_black.svg",
          "dark": "flutter_helpers/explorer/assets/start_icon.svg"
        }
      },
      {
        "command": "flutter-tasks.screenShot",
        "title": "Run The Command",
        "icon": {
          "light": "flutter_helpers/explorer/assets/flutter_screen_shot_dark.gif",
          "dark": "flutter_helpers/explorer/assets/flutter_screen_shot.gif"
        }
      },
      {
        "command": "flutter-tasks.doctor",
        "title": "Run The Command",
        "icon": {
          "light": "flutter_helpers/explorer/assets/flutter_doctor_light.gif",
          "dark": "flutter_helpers/explorer/assets/flutter_doctor_dark.gif"
        }
      },
      {
        "command": "flutter-tasks.copyTheCommand",
        "title": "Copy"
      },
      {
        "command": "flutter-tasks.openSettingsJson",
        "title": "Open Settings Json",
        "icon": {
          "light": "flutter_helpers/explorer/assets/code_light.gif",
          "dark": "flutter_helpers/explorer/assets/settings_hover.gif"
        }
      },
      {
        "command": "flutter-tasks.openSettingsJsonWithIcon",
        "title": "Open Settings Json",
        "icon": {
          "light": "flutter_helpers/explorer/assets/code_light.gif",
          "dark": "flutter_helpers/explorer/assets/settings_hover.gif"
        }
      },
      {
        "command": "flutter-tasks.activateCustomCommands",
        "title": "Open Settings Json",
        "icon": {
          "light": "flutter_helpers/explorer/assets/code_light.gif",
          "dark": "flutter_helpers/explorer/assets/open_folder_new.gif"
        }
      },
      {
        "command": "flutter-tasks.newIdea",
        "title": "Open Settings Json",
        "icon": {
          "light": "flutter_helpers/explorer/assets/code_light.gif",
          "dark": "flutter_helpers/explorer/assets/open_folder_new.gif"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "flutter-tasks.openSettingsJson",
          "when": "editorTextFocus && editorLangId == dart",
          "group": "navigation"
        }
      ],
      "keybindings": [
        {
          "command": "flutter-tasks.activateFlavor",
          "key": "alt + f",
          "when": "editorTextFocus"
        }
      ],
      "view/item/context": [
        {
          "command": "flutter-tasks.runTheCommand",
          "when": "view == flutter-Commands && viewItem == child || view == flutterView && viewItem == child",
          "group": "inline"
        },
        {
          "command": "flutter-tasks.screenShot",
          "when": "view == flutter-Commands && viewItem == screenShot || view == flutterView && viewItem == screenShot",
          "group": "inline"
        },
        {
          "command": "flutter-tasks.doctor",
          "when": "view == flutter-Commands && viewItem == doctor || view == flutterView && viewItem == doctor",
          "group": "inline"
        },
        {
          "command": "flutter-tasks.runTheCommand",
          "when": "view == flutter-Commands && viewItem == child || viewItem == doctor || viewItem == screenShot"
        },
        {
          "command": "flutter-tasks.copyTheCommand",
          "when": "view == flutter-Commands && viewItem == child || viewItem == doctor || viewItem == screenShot || viewItem == gitHubContext"
        },
        {
          "command": "flutter-tasks.openSettingsJsonWithIcon",
          "when": "view == flutter-Commands && viewItem == settings",
          "group": "inline"
        },
        {
          "command": "flutter-tasks.editLocale",
          "when": "view == flutter-Commands && viewItem == easyLocale",
          "group": "inline"
        },
        {
          "command": "flutter-tasks.openIos",
          "when": "view == flutter-Commands && viewItem == OpenIos || view == flutterView && viewItem == OpenIos",
          "group": "inline"
        },
        {
          "command": "flutter-tasks.openApkFolder",
          "when": "view == flutter-Commands && viewItem == android || view == flutterView && viewItem == android",
          "group": "inline"
        },
        {
          "command": "flutter-tasks.openbundleFolder",
          "when": "view == flutter-Commands && viewItem == bundle || view == flutterView && viewItem == bundle",
          "group": "inline"
        },
        {
          "command": "flutter-tasks.activateCustomCommands",
          "when": "view == flutter-Commands && viewItem == customCommands",
          "group": "inline"
        },
        {
          "command": "flutter-tasks.newIdea",
          "when": "view == flutter-Commands && viewItem == newIdea",
          "group": "inline"
        }
      ],
      "view/title": [
        {
          "command": "flutter-tasks.refreshEntry",
          "when": "view == flutter-Commands || view == flutterView",
          "group": "navigation"
        },
        {
          "command": "flutter-tasks.openSettingsJson",
          "when": "view == flutter-Commands || view == flutterView",
          "group": "navigation"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "flutter-Commands",
        "contents": "Loading Settings... ⏳🔄"
      },
      {
        "view": "flutterView",
        "contents": "Loading Settings 🔨"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "flutter-commands-container",
          "title": "Simpler Flutter Tasks",
          "icon": "flutter_helpers/explorer/assets/ios_assets.svg"
        }
      ]
    },
    "views": {
      "flutter-commands-container": [
        {
          "id": "flutter-Commands",
          "name": "Commands"
        }
      ],
      "explorer": [
        {
          "id": "flutterView",
          "name": "Simpler Flutter Tasks 😉"
        }
      ]
    },
    "configuration": {
      "title": "Simpler Flutter Tasks",
      "properties": {
        "SimplerFlutterTasks.buildRunnerCategoryExpandable": {
          "type": "boolean",
          "default": false,
          "enum": [
            false,
            true
          ],
          "enumDescriptions": [
            "Always Expand -> false",
            "Always Expand -> true"
          ],
          "description": "Complete boolean with hide or show Icon"
        },
        "SimplerFlutterTasks.flutterCategoryExpandable": {
          "type": "boolean",
          "default": false,
          "enum": [
            false,
            true
          ],
          "enumDescriptions": [
            "Always Expand -> false",
            "Always Expand -> true"
          ],
          "description": "Complete boolean with hide or show Icon"
        },
        "SimplerFlutterTasks.androidCategoryExpandable": {
          "type": "boolean",
          "default": false,
          "enum": [
            false,
            true
          ],
          "enumDescriptions": [
            "Always Expand -> false",
            "Always Expand -> true"
          ],
          "description": "Complete boolean with hide or show Icon"
        },
        "SimplerFlutterTasks.iosCategoryExpandable": {
          "type": "boolean",
          "default": false,
          "enum": [
            false,
            true
          ],
          "enumDescriptions": [
            "Always Expand -> false",
            "Always Expand -> true"
          ],
          "description": "Complete boolean with hide or show Icon"
        },
        "SimplerFlutterTasks.gitCategoryExpandable": {
          "type": "boolean",
          "default": false,
          "enum": [
            false,
            true
          ],
          "enumDescriptions": [
            "Always Expand -> false",
            "Always Expand -> true"
          ],
          "description": "Complete boolean with hide or show Icon"
        },
        "SimplerFlutterTasks.flutterCleanIcon": {
          "type": "string",
          "default": "show",
          "enum": [
            "show",
            "hide"
          ],
          "enumDescriptions": [
            "Clean icon -> show",
            "Clean icon -> hide"
          ],
          "description": "Complete boolean with hide or show Icon"
        },
        "SimplerFlutterTasks.flutterPubGetIcon": {
          "type": "string",
          "default": "show",
          "enum": [
            "show",

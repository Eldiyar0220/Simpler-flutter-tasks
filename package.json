          ],
          "description": "Complete String with hide or show Icon"
        },
        "SimplerFlutterTasks.smallApkIcon": {
          "type": "string",
          "default": "hide",
          "enum": [
            "show",
            "hide"
          ],
          "enumDescriptions": [
            "Small Apk icon -> show",
            "Small Apk icon -> hide"
          ],
          "description": "Complete String with hide or show Icon"
        },
        "SimplerFlutterTasks.spiderBuildIcon": {
          "type": "string",
          "default": "hide",
          "enum": [
            "show",
            "hide"
          ],
          "enumDescriptions": [
            "Spider Build icon -> show",
            "Spider Build icon -> hide"
          ],
          "description": "Complete String with hide or show Icon"
        },
        "SimplerFlutterTasks.flutterFlavor": {
          "type": "string",
          "default": "hide",
